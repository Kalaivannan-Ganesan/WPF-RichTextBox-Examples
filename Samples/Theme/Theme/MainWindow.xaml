<syncfusion:RibbonWindow x:Class="Theme.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        xmlns:local="clr-namespace:Theme"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        xmlns:syncfusionskin ="clr-namespace:Syncfusion.SfSkinManager;assembly=Syncfusion.SfSkinManager.WPF"
        syncfusionskin:SfSkinManager.Theme="{syncfusionskin:SkinManagerExtension ThemeName=Windows11Light}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <syncfusion:SfRichTextRibbon x:Name="richTextRibbon" 
                                     SnapsToDevicePixels="True"  
                                     DataContext="{Binding ElementName=richTextBoxAdv}"/>
        <syncfusion:SfRichTextBoxAdv x:Name="richTextBoxAdv" 
                                     Background="#F1F1F1" 
                                     Grid.Row="1"/>
    </Grid>
</syncfusion:RibbonWindow>